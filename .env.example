# QuantSwarm v3 — Environment Variables
# Copy to .env and fill in values

# === DATA SOURCES (Free tier available) ===
# Reddit (free): https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_secret
REDDIT_USER_AGENT=QuantSwarm/3.0

# Twitter/X — Nitter RSS (free, no key needed)
# Set TWITTER_MODE=nitter for free, or twitter_api for paid
TWITTER_MODE=nitter
TWITTER_BEARER_TOKEN=optional_if_using_api

# SEC EDGAR (completely free, no key)
SEC_USER_AGENT=YourName your@email.com

# News RSS — free sources
NEWS_RSS_FEEDS=https://feeds.reuters.com/reuters/businessNews,https://feeds.bloomberg.com/markets/news.rss

# On-chain (Glassnode free tier or Dune)
GLASSNODE_API_KEY=optional_free_tier
DUNE_API_KEY=optional

# Market data
ALPACA_API_KEY=your_alpaca_key
ALPACA_SECRET_KEY=your_alpaca_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Crypto (Binance free)
BINANCE_API_KEY=your_binance_key
BINANCE_SECRET=your_binance_secret

# === MODELS ===
FINBERT_MODEL=ProsusAI/finbert
DEVICE=cpu   # or cuda

# === RISK SETTINGS ===
MAX_POSITION_PCT=0.10
MAX_DRAWDOWN_PCT=0.15
KELLY_FRACTION=0.25
STOP_LOSS_PCT=0.05

# === ALERTS ===
TELEGRAM_BOT_TOKEN=your_telegram_token
TELEGRAM_CHAT_ID=your_chat_id
SLACK_WEBHOOK=optional_slack_webhook

# === DATABASE ===
DATABASE_URL=sqlite:///./quantswarm.db

# === PAPER / LIVE ===
TRADING_MODE=paper   # paper or live — NEVER set live without full validation

# === MIROFISH SWARM ===
MIROFISH_N_AGENTS=1000
MIROFISH_SEED=42
